# Copy to deploy/cloud/.env on the server and fill with real values.
# Never commit deploy/cloud/.env.

APP_DOMAIN=linje.dev
ACME_EMAIL=admin@example.com

AUTH_SECRET=replace-with-strong-random-secret
NEXTAUTH_URL=https://linje.dev

SUPABASE_PG_URL=postgresql://postgres:replace-with-password@db.example.supabase.co:5432/postgres
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
STRIPE_PRICE_PRO=replace-with-stripe-pro-price
STRIPE_PRICE_TEAM=replace-with-stripe-team-price
STRIPE_PRICE_ENTERPRISE=replace-with-stripe-enterprise-price

GOOGLE_MAPS_API_KEY=replace-with-google-maps-api-key
CESIUM_ION_TOKEN=replace-with-cesium-ion-token

PROXY_HOST_ALLOWLIST=
